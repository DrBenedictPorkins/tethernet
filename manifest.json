{
  "manifest_version": 3,
  "name": "Tethernet",
  "version": "1.0.0",
  "description": "Connect Chrome to a local AI coding session. DOM inspection, network capture, request interception & mocking, and page interaction. Localhost only.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation",
    "webRequest",
    "cookies",
    "scripting",
    "offscreen",
    "debugger",
    "windows",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "readability.js",
        "turndown.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Tethernet"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
